{
  "name": "@mrhammadclaw/synology-chat",
  "version": "2026.2.26",
  "description": "Synology Chat channel plugin for MrHammadClaw",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "mrhammadclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "synology-chat",
