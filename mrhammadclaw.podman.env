# MrHammadClaw Podman environment
# Copy to mrhammadclaw.podman.env.local and set MRHAMMADCLAW_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   MRHAMMADCLAW_PODMAN_ENV=/path/to/mrhammadclaw.podman.env ./scripts/run-mrhammadclaw-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-mrhammadclaw-podman.sh which can generate it).
MRHAMMADCLAW_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
MRHAMMADCLAW_PODMAN_GATEWAY_HOST_PORT=18789
MRHAMMADCLAW_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
MRHAMMADCLAW_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
