# MrHammadClaw gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into mrhammadclaw's ~/.config/containers/systemd/
# {{MRHAMMADCLAW_HOME}} is replaced at install time.

[Unit]
Description=MrHammadClaw gateway (rootless Podman)

[Container]
Image=mrhammadclaw:local
ContainerName=mrhammadclaw
UserNS=keep-id
Volume={{MRHAMMADCLAW_HOME}}/.mrhammadclaw:/home/node/.mrhammadclaw
EnvironmentFile={{MRHAMMADCLAW_HOME}}/.mrhammadclaw/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
